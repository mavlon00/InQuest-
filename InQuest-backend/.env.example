# InQuest Mobility Service - Environment Configuration
# Copy this file to .env and fill in actual values

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME="InQuest Mobility Service"
APP_DESCRIPTION="Safety-first urban mobility platform in Nigeria"
VERSION="1.0.0"
DEBUG=false
ENVIRONMENT="development"  # development, staging, production

# ============================================================================
# DATABASE - PostgreSQL
# ============================================================================
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL="postgresql+asyncpg://inquest:password@localhost:5432/inquest_db"
SQLALCHEMY_ECHO=false
DB_POOL_SIZE=20
DB_POOL_MAX_OVERFLOW=10

# ============================================================================
# JWT & SECURITY
# ============================================================================
# For production, use a strong random key (min 32 chars)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY="your-super-secret-key-change-this-in-production-minimum-32-characters"
ALGORITHM="HS256"

# Token expiry in seconds
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=900     # 15 minutes
JWT_REFRESH_TOKEN_EXPIRE_SECONDS=2592000  # 30 days
OTP_EXPIRE_SECONDS=300                  # 5 minutes

# ============================================================================
# OTP & SMS CONFIGURATION
# ============================================================================
OTP_LENGTH=6
OTP_MAX_RESEND_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_LOCK_DURATION_SECONDS=1800  # 30 minutes

SMS_PROVIDER="termii"  # Options: termii, twilio

# Termii SMS Provider
TERMII_API_KEY="your-termii-api-key"
TERMII_SENDER_ID="InQuest"

# Twilio SMS Provider (alternative)
TWILIO_ACCOUNT_SID="your-twilio-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+234xxxxxxxxxx"

# ============================================================================
# PAYMENT GATEWAYS
# ============================================================================
# Paystack
PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxx"
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxx"
PAYSTACK_WEBHOOK_SECRET="your-paystack-webhook-secret"

# Flutterwave (alternative)
FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_TEST_xxxxxxxxxxxxx"
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST_xxxxxxxxxxxxx"
FLUTTERWAVE_WEBHOOK_SECRET="your-flutterwave-webhook-secret"

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================
# Google Maps
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Firebase Cloud Messaging (FCM)
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY="your-firebase-private-key"
FIREBASE_CLIENT_EMAIL="your-firebase-client-email"

# ============================================================================
# REDIS CACHE & SESSION STORE
# ============================================================================
REDIS_URL="redis://localhost:6379/0"
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=""  # Leave empty if no auth

# ============================================================================
# MQTT/IoT (Optional for driver app)
# ============================================================================
MQTT_BROKER="mqtt.example.com"
MQTT_PORT=1883
MQTT_USERNAME=""
MQTT_PASSWORD=""
MQTT_TOPIC_PREFIX="inquest/"

# ============================================================================
# CORS & SECURITY
# ============================================================================
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000,https://inquest.ng"

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_OTP_RESEND=3          # Max OTP resends per hour
RATE_LIMIT_OTP_VERIFY=5          # Max verify attempts
RATE_LIMIT_LOGIN=10              # Max login attempts
RATE_LIMIT_WINDOW_SECONDS=3600   # 1 hour

# ============================================================================
# GEOLOCATION
# ============================================================================
ON_SPOT_BOOKING_RADIUS_METERS=500    # Max distance for on-spot booking
DRIVER_SEARCH_RADIUS_KM=5            # Search radius for drivers
ARRIVING_THRESHOLD_METERS=100        # Distance for "arriving" status
COMPLETING_THRESHOLD_METERS=300      # Distance for "completing" status

# ============================================================================
# FARE CONFIGURATION (NGN - Nigerian Naira)
# ============================================================================
BASE_FARE_NGN=100.0              # Flag fall
PER_KM_RATE_NGN=120.0            # Per km rate
DEAD_MILEAGE_RATE_NGN=125.0      # Dead mileage rate
STOP_FEE_NGN=100.0               # Per additional stop
INSURANCE_FEE_NGN=100.0          # Insurance fee
WAITING_FEE_PER_MINUTE_NGN=30.0  # Waiting charge per minute
WAITING_GRACE_MINUTES=5          # Grace period before waiting fee
CANCELLATION_FEE_NGN=150.0       # Cancellation fee
CANCELLATION_GRACE_MINUTES=3     # Grace period before fee applies

# ============================================================================
# MEMBERSHIP TIER THRESHOLDS
# ============================================================================
# Silver Tier
SILVER_MIN_TRIPS=10
SILVER_MIN_POINTS=500
SILVER_DISCOUNT=0.02  # 2%

# Gold Tier
GOLD_MIN_TRIPS=30
GOLD_MIN_POINTS=1500
GOLD_DISCOUNT=0.05   # 5%

# Platinum Tier
PLATINUM_MIN_TRIPS=50
PLATINUM_MIN_POINTS=3000
PLATINUM_DISCOUNT=0.10  # 10%
PLATINUM_FREE_INSURANCE=true

# ============================================================================
# GREEN POINTS
# ============================================================================
GREEN_POINTS_PER_100_NGN=1       # 1 point per 100 NGN spent
GREEN_POINTS_REFERRAL_BONUS=5    # Points for successful referral
GREEN_POINTS_EXPIRY_DAYS=365     # Annual expiry
GREEN_POINTS_REDEMPTION_RATE=0.1 # 100 points = NGN 10
GREEN_POINTS_MIN_REDEMPTION=100  # Min points to redeem

# ============================================================================
# REFERRAL SYSTEM
# ============================================================================
REFERRAL_CODE_LENGTH=6
REFERRAL_REWARD_REFERRER_NGN=500.0   # Amount credited to referrer
REFERRAL_REWARD_REFERRED_DISCOUNT_NGN=200.0  # Discount for new user

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT="json" # json or text
SENTRY_DSN=""     # Leave empty to disable error tracking

# ============================================================================
# CELERY BACKGROUND JOBS
# ============================================================================
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"
CELERY_TIMEZONE="Africa/Lagos"

# ============================================================================
# FILE STORAGE (CDN)
# ============================================================================
STORAGE_PROVIDER="s3"  # Options: s3, gcs, local
S3_BUCKET_NAME="inquest-mobility"
S3_REGION="us-east-1"
S3_ACCESS_KEY="your-aws-access-key"
S3_SECRET_KEY="your-aws-secret-key"
CDN_BASE_URL="https://cdn.inquest.ng"

# ============================================================================
# WEBSOCKET
# ============================================================================
WEBSOCKET_HEARTBEAT_INTERVAL=30  # Ping interval in seconds
WEBSOCKET_HEARTBEAT_TIMEOUT=10   # Pong timeout in seconds
